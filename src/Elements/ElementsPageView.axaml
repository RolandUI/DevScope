<UserControl
  x:Class="ClassicDiagnostics.Avalonia.Elements.ElementsPageView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ClassicDiagnostics.Avalonia.Controls"
  xmlns:elements="using:ClassicDiagnostics.Avalonia.Elements"
  xmlns:views="using:ClassicDiagnostics.Avalonia.Views"
  x:DataType="elements:ElementsPageViewModel">

  <UserControl.Styles>
    <Style Selector="Border.FindBar">
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
    </Style>

    <Style Selector="Button.FindButton">
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style Selector="TextBlock.FindStatus">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="Gray"/>
    </Style>

    <Style Selector="TabItem.DetailsTab">
      <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style Selector="ToggleButton.TreeModeButton">
      <Setter Property="Padding" Value="2"/>
    </Style>

    <Style Selector="Image.Icon">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="0.35*,1,0.65*">
    <Grid
      Grid.Column="0"
      RowDefinitions="Auto,*,Auto">
      <DockPanel
        Grid.Row="0"
        LastChildFill="False">
        <TextBlock
          Margin="8,0"
          VerticalAlignment="Center"
          FontWeight="SemiBold"
          Text="Tree"/>
        <StackPanel
          DockPanel.Dock="Right"
          Margin="4,0"
          Orientation="Horizontal"
          Spacing="2">
          <ToggleButton
            Classes="TreeModeButton"
            Command="{Binding SelectLogicalTree}"
            IsChecked="{Binding IsLogicalTreeSelected, Mode=OneWay}"
            ToolTip.Tip="Logical tree">
            <Image Classes="Icon" Source="{StaticResource LucideListTree}"/>
          </ToggleButton>
          <ToggleButton
            Classes="TreeModeButton"
            Command="{Binding SelectVisualTree}"
            IsChecked="{Binding IsVisualTreeSelected, Mode=OneWay}"
            ToolTip.Tip="Visual tree">
            <Image Classes="Icon" Source="{StaticResource LucideScanEye}"/>
          </ToggleButton>
        </StackPanel>
      </DockPanel>

      <ContentControl
        Grid.Row="1"
        Content="{Binding CurrentTree}"/>

      <Border
        Grid.Row="2"
        Classes="FindBar"
        IsVisible="{Binding Find.IsVisible}">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
          <controls:FilterTextBox
            x:Name="FindTextBox"
            PlaceholderText="Find by string or selector"
            Text="{Binding Find.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            UseCaseSensitiveFilter="{Binding Find.UseCaseSensitiveFilter}"
            UseRegexFilter="{Binding Find.UseRegexFilter}"
            UseWholeWordFilter="{Binding Find.UseWholeWordFilter}"/>
          <TextBlock
            Grid.Column="1"
            Margin="6,0"
            Classes="FindStatus"
            Text="{Binding Find.StatusText}"/>
          <Button
            Grid.Column="2"
            Classes="FindButton"
            Click="HandleFindPreviousClick"
            ToolTip.Tip="Previous match">
            <TextBlock Text="Prev"/>
          </Button>
          <Button
            Grid.Column="3"
            Classes="FindButton"
            Click="HandleFindNextClick"
            ToolTip.Tip="Next match">
            <TextBlock Text="Next"/>
          </Button>
          <Button
            Grid.Column="4"
            Classes="FindButton"
            Click="HandleCloseFindClick"
            ToolTip.Tip="Close find">
            <TextBlock Text="x"/>
          </Button>
        </Grid>
      </Border>

    </Grid>

    <GridSplitter
      Grid.Column="1"
      Width="1"
      Background="{DynamicResource ThemeControlMidBrush}"
      ResizeDirection="Columns"/>

    <Grid
      Grid.Column="2">
      <TextBlock
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Foreground="Gray"
        IsVisible="{Binding CurrentDetails, Converter={x:Static ObjectConverters.IsNull}}"
        Text="No element selected"/>

      <TabControl
        BorderThickness="0"
        IsVisible="{Binding CurrentDetails, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TabItem Classes="DetailsTab" Header="Styles">
          <views:ControlStylesView DataContext="{Binding CurrentDetails}"/>
        </TabItem>
        <TabItem Classes="DetailsTab" Header="Properties">
          <views:ControlPropertiesView DataContext="{Binding CurrentDetails}"/>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</UserControl>
