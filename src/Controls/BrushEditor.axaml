<Styles
  xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ClassicDiagnostics.Avalonia.Controls" x:ClassModifier="internal">
  <Design.PreviewWith>
    <controls:BrushEditor/>
  </Design.PreviewWith>

  <Style Selector=":is(controls|BrushEditor)">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <Button
            x:Name="PART_ClearButton" HorizontalAlignment="Right"
            VerticalContentAlignment="Center"
            Theme="{StaticResource SimpleTextBoxClearButtonTheme}"/>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>