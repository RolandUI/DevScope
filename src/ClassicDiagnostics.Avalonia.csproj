<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Bringing the classic F12 DevTools back to Avalonia 12+. A community-maintained migration of the Avalonia 11 Avalonia.Diagnostics codebase.</Description>
    <Authors>Sylinko;The Avalonia Project</Authors>
    <PackageProjectUrl>https://github.com/Sylinko/ClassicDiagnostics.Avalonia</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Sylinko/ClassicDiagnostics.Avalonia</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>avalonia;devtools;diagnostics;f12</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia"/>
    <PackageReference Include="Avalonia.Controls.ColorPicker"/>
    <PackageReference Include="Avalonia.Controls.DataGrid"/>
    <PackageReference Include="Avalonia.Themes.Simple"/>
    <PackageReference Include="CommunityToolkit.Mvvm"/>
    <PackageReference Include="IgnoresAccessChecksToGenerator">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <IgnoresAccessChecksTo Include="Avalonia"/>
    <IgnoresAccessChecksTo Include="Avalonia.Base"/>
    <IgnoresAccessChecksTo Include="Avalonia.Controls"/>
  </ItemGroup>

</Project>
