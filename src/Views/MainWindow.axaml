<Window
  x:Class="ClassicDiagnostics.Avalonia.Views.MainWindow" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:diag="using:ClassicDiagnostics.Avalonia"
  xmlns:viewModels="using:ClassicDiagnostics.Avalonia.ViewModels" xmlns:views="using:ClassicDiagnostics.Avalonia.Views"
  Title="Native DevTools Reborn in Avalonia 12" x:DataType="viewModels:MainViewModel">
  <Window.DataTemplates>
    <diag:ViewLocator/>
  </Window.DataTemplates>

  <Window.Styles>
    <SimpleTheme/>
    <StyleInclude Source="avares://ClassicDiagnostics.Avalonia/Controls/ThicknessEditor.axaml"/>
    <StyleInclude Source="avares://ClassicDiagnostics.Avalonia/Controls/FilterTextBox.axaml"/>
    <StyleInclude Source="avares://ClassicDiagnostics.Avalonia/Controls/BrushEditor.axaml"/>
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Simple/Simple.xaml"/>
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml"/>
  </Window.Styles>
  <views:MainView/>
</Window>