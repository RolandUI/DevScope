<UserControl
  x:Class="ClassicDiagnostics.Avalonia.Views.Elements.Styles.ElementLayoutView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:ClassicDiagnostics.Avalonia.Views.Controls"
  xmlns:styles="using:ClassicDiagnostics.Avalonia.Elements.Styles" xmlns:valueConverters="clr-namespace:ClassicDiagnostics.Avalonia.ValueConverters"
  x:DataType="styles:ElementLayoutViewModel">

  <UserControl.Resources>
    <SolidColorBrush
      x:Key="SizeGuidelineBrush" Color="#333333"/>
    <SolidColorBrush
      x:Key="MarginBackgroundBrush" Color="#D78965"/>
    <SolidColorBrush
      x:Key="MarginHighlightBrush" Color="#EA966F"/>
    <SolidColorBrush
      x:Key="BorderBackgroundBrush" Color="#E3C381"/>
    <SolidColorBrush
      x:Key="BorderHighlightBrush" Color="#EFCD88"/>
    <SolidColorBrush
      x:Key="PaddingBackgroundBrush" Color="#B8C47F"/>
    <SolidColorBrush
      x:Key="PaddingHighlightBrush" Color="#CEDA8E"/>
    <SolidColorBrush
      x:Key="SizeBackgroundBrush" Color="#88B2BD"/>
    <SolidColorBrush
      x:Key="SizeHighlightBrush" Color="#9ED0DC"/>
    <SolidColorBrush
      x:Key="ThicknessEditorForeground" Color="Black"/>
  </UserControl.Resources>

  <Grid RowDefinitions="*,Auto">

    <Viewbox
      Grid.Row="0" StretchDirection="DownOnly">
      <Grid
        x:Name="LayoutRoot" Margin="8,0,8,8"
        ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto">

        <Grid.Styles>
          <Style Selector="TextBlock.With_Constraint">
            <Setter Property="TextDecorations" Value="Underline"/>
          </Style>

        </Grid.Styles>

        <Border
          x:Name="VerticalSize" Grid.Row="0"
          Grid.Column="1">
          <TextBlock
            VerticalAlignment="Center"
            Classes.With_Constraint="{Binding HeightConstraint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            FontWeight="Bold"
            Text="{Binding Height}"
            ToolTip.Tip="{Binding HeightConstraint}"/>
        </Border>

        <Border
          x:Name="HorizontalSize" Grid.Row="1"
          Grid.Column="0">
          <TextBlock
            HorizontalAlignment="Center"
            Classes.With_Constraint="{Binding WidthConstraint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            FontWeight="Bold"
            Text="{Binding Width}"
            ToolTip.Tip="{Binding WidthConstraint}"/>
        </Border>

        <controls:ThicknessEditor
          Grid.Row="0" Grid.Column="0"
          HorizontalAlignment="Center" VerticalAlignment="Top"
          Background="{StaticResource MarginBackgroundBrush}"
          Foreground="{StaticResource ThicknessEditorForeground}"
          Header="margin"
          Highlight="{StaticResource MarginHighlightBrush}"
          Thickness="{Binding MarginThickness}">
          <controls:ThicknessEditor
            x:Name="BorderArea"
            Background="{StaticResource BorderBackgroundBrush}"
            Header="border"
            Highlight="{StaticResource BorderHighlightBrush}"
            IsPresent="{Binding HasBorder}"
            Thickness="{Binding BorderThickness}">
            <controls:ThicknessEditor
              x:Name="PaddingArea"
              Background="{StaticResource PaddingBackgroundBrush}"
              Header="padding"
              Highlight="{StaticResource PaddingHighlightBrush}"
              IsPresent="{Binding HasPadding}"
              Thickness="{Binding PaddingThickness}">
              <Border
                x:Name="ContentArea" MinWidth="100"
                MinHeight="16" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" BorderThickness="1">
                <Border.Styles>
                  <Style Selector="Border">
                    <Setter Property="Background" Value="{StaticResource SizeBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThicknessBorderBrush}"/>
                  </Style>
                  <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="{StaticResource SizeHighlightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                  </Style>
                </Border.Styles>
                <TextBlock
                  Margin="2" HorizontalAlignment="Center"
                  VerticalAlignment="Center" Text="content"/>
              </Border>
            </controls:ThicknessEditor>
          </controls:ThicknessEditor>
        </controls:ThicknessEditor>

        <Canvas
          Grid.Row="0" Grid.RowSpan="2"
          Grid.Column="0" Grid.ColumnSpan="2">
          <Canvas.Styles>
            <Style Selector="Rectangle">
              <Setter Property="StrokeDashArray" Value="1,3"/>
              <Setter Property="Stroke" Value="{StaticResource SizeGuidelineBrush}"/>
              <Setter Property="StrokeThickness" Value="1"/>
              <Setter Property="IsHitTestVisible" Value="False"/>
            </Style>
          </Canvas.Styles>
          <Rectangle x:Name="HorizontalSizeBegin"/>
          <Rectangle x:Name="HorizontalSizeEnd"/>
          <Rectangle x:Name="VerticalSizeBegin"/>
          <Rectangle x:Name="VerticalSizeEnd"/>
        </Canvas>
      </Grid>
    </Viewbox>

    <StackPanel
      Grid.Row="1" Grid.Column="0"
      Margin="4" HorizontalAlignment="Stretch"
      Orientation="Vertical" Spacing="4">

      <StackPanel.Styles>
        <Style Selector="RadioButton">
          <Setter Property="Template">
            <ControlTemplate>
              <Border
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}">
                <Path
                  x:Name="PART_Path" Width="16"
                  Height="16" Fill="Black"
                  Stretch="Uniform"/>
              </Border>
            </ControlTemplate>
          </Setter>
        </Style>

        <Style Selector="RadioButton">
          <Setter Property="Background" Value="WhiteSmoke"/>
          <Setter Property="Padding" Value="2"/>
        </Style>

        <Style Selector="RadioButton:pointerover">
          <Setter Property="Background" Value="{DynamicResource ThemeControlHighlightMidBrush}"/>
        </Style>

        <Style Selector="RadioButton:checked">
          <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush4}"/>
        </Style>

      </StackPanel.Styles>

      <DockPanel
        HorizontalAlignment="Stretch" LastChildFill="True">

        <DockPanel.Styles>
          <Style Selector="RadioButton.H_Left /template/ Path#PART_Path">
            <Setter Property="Data" Value="M22 13V19H6V13H22M6 5V11H16V5H6M2 2V22H4V2H2"/>
          </Style>
          <Style Selector="RadioButton.H_Center /template/ Path#PART_Path">
            <Setter Property="Data" Value="M20 19H13V22H11V19H4V13H11V11H7V5H11V2H13V5H17V11H13V13H20V19Z"/>
          </Style>
          <Style Selector="RadioButton.H_Right /template/ Path#PART_Path">
            <Setter Property="Data" Value="M18 13V19H2V13H18M8 5V11H18V5H8M20 2V22H22V2H20Z"/>
          </Style>
          <Style Selector="RadioButton.H_Stretch /template/ Path#PART_Path">
            <Setter Property="Data" Value="M4,22H2V2h2V22z M22,2h-2v20h2V2z M13.5,7h-3v10h3V7z"/>
          </Style>
        </DockPanel.Styles>

        <Label
          DockPanel.Dock="Left" Content="Horizontal Alignment"/>

        <StackPanel
          HorizontalAlignment="Right" Orientation="Horizontal">
          <RadioButton
            Classes="H_Left" GroupName="HAlignment"
            IsChecked="{Binding HorizontalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static HorizontalAlignment.Left}}"
            ToolTip.Tip="Left"/>
          <RadioButton
            Classes="H_Center" BorderThickness="0,1,1,1"
            GroupName="HAlignment"
            IsChecked="{Binding HorizontalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static HorizontalAlignment.Center}}"
            ToolTip.Tip="Center"/>
          <RadioButton
            Classes="H_Right" BorderThickness="0,1,1,1"
            GroupName="HAlignment"
            IsChecked="{Binding HorizontalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static HorizontalAlignment.Right}}"
            ToolTip.Tip="Right"/>
          <RadioButton
            Classes="H_Stretch" GroupName="HAlignment"
            IsChecked="{Binding HorizontalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static HorizontalAlignment.Stretch}}"
            ToolTip.Tip="Stretch"/>
        </StackPanel>

      </DockPanel>

      <DockPanel
        HorizontalAlignment="Stretch" LastChildFill="True">
        <DockPanel.Styles>
          <Style Selector="RadioButton.V_Top /template/ Path#PART_Path">
            <Setter Property="Data" Value="M11 22H5V6H11V22M19 6H13V16H19V6M22 2H2V4H22V2Z"/>
          </Style>
          <Style Selector="RadioButton.V_Center /template/ Path#PART_Path">
            <Setter Property="Data" Value="M5 20V13H2V11H5V4H11V11H13V7H19V11H22V13H19V17H13V13H11V20H5Z"/>
          </Style>
          <Style Selector="RadioButton.V_Bottom /template/ Path#PART_Path">
            <Setter Property="Data" Value="M11 18H5V2H11V18M19 8H13V18H19V8M22 20H2V22H22V20Z"/>
          </Style>
          <Style Selector="RadioButton.V_Stretch /template/ Path#PART_Path">
            <Setter Property="Data" Value="M22,2v2H2V2H22z M7,10.5v3h10v-3H7z M2,20v2h20v-2H2z"/>
          </Style>
        </DockPanel.Styles>

        <Label
          DockPanel.Dock="Left" Content="Vertical Alignment"/>

        <StackPanel
          HorizontalAlignment="Right" Orientation="Horizontal">
          <RadioButton
            Classes="V_Top" GroupName="VAlignment"
            IsChecked="{Binding VerticalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static VerticalAlignment.Top}}"
            ToolTip.Tip="Top"/>
          <RadioButton
            Classes="V_Center" BorderThickness="0,1,1,1"
            GroupName="VAlignment"
            IsChecked="{Binding VerticalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static VerticalAlignment.Center}}"
            ToolTip.Tip="Center"/>
          <RadioButton
            Classes="V_Bottom" BorderThickness="0,1,1,1"
            GroupName="VAlignment"
            IsChecked="{Binding VerticalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static VerticalAlignment.Bottom}}"
            ToolTip.Tip="Bottom"/>
          <RadioButton
            Classes="V_Stretch" GroupName="VAlignment"
            IsChecked="{Binding VerticalAlignment, Converter={x:Static valueConverters:EnumToCheckedConverter.Shared}, ConverterParameter={x:Static VerticalAlignment.Stretch}}"
            ToolTip.Tip="Stretch"/>
        </StackPanel>

      </DockPanel>
    </StackPanel>
  </Grid>

</UserControl>
