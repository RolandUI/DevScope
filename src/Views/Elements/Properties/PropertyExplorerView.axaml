<UserControl
  x:Class="RolandUI.DevScope.Views.Elements.Properties.PropertyExplorerView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="using:RolandUI.DevScope.Views.Elements.Properties"
  xmlns:properties="using:RolandUI.DevScope.Elements.Properties.ViewModels" x:DataType="properties:PropertyExplorerViewModel">

  <UserControl.DataTemplates>
    <DataTemplate DataType="properties:PropertyDrillInViewModel">
      <local:PropertyDrillInView/>
    </DataTemplate>
    <DataTemplate DataType="properties:PropertyColumnsViewModel">
      <local:PropertyColumnsView/>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid RowDefinitions="Auto,*">
    <DockPanel
      Grid.Row="0" Margin="4,2">
      <StackPanel
        DockPanel.Dock="Right" Orientation="Horizontal"
        Spacing="2">
        <ToggleButton
          Command="{Binding SetMode}"
          CommandParameter="{x:Static properties:PropertyNavigationMode.Columns}"
          Content="Columns"
          IsChecked="{Binding NavigationMode, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static properties:PropertyNavigationMode.Columns}}"/>
        <ToggleButton
          Command="{Binding SetMode}"
          CommandParameter="{x:Static properties:PropertyNavigationMode.DrillIn}"
          Content="Drill In"
          IsChecked="{Binding NavigationMode, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static properties:PropertyNavigationMode.DrillIn}}"
          IsHitTestVisible="{Binding !$self.IsChecked}"/>
      </StackPanel>
      <Button
        Command="{Binding DrillIn.NavigateBack}"
        Content="Back"
        IsEnabled="{Binding DrillIn.CanNavigateBack}"
        IsVisible="{Binding NavigationMode, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static properties:PropertyNavigationMode.DrillIn}}"/>
    </DockPanel>

    <ContentControl
      Grid.Row="1"
      Content="{Binding CurrentMode}"/>
  </Grid>
</UserControl>