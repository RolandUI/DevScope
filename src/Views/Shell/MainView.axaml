<UserControl
  x:Class="ClassicDiagnostics.Avalonia.Views.Shell.MainView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:diag="using:ClassicDiagnostics.Avalonia"
  xmlns:shell="using:ClassicDiagnostics.Avalonia.Shell" x:DataType="shell:MainViewModel">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Assets/Icons.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Image.Icon">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
    </Style>
  </UserControl.Styles>

  <Grid
    ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,*,Auto">
    <HyperlinkButton
      Grid.Row="0" Grid.Column="0"
      Grid.ColumnSpan="2" Padding="0,4"
      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
      VerticalContentAlignment="Center" Background="#F3ECC0"
      Content="Try the new Avalonia Dev Tools - now available in Accelerate." CornerRadius="0"
      FontSize="13" FontWeight="Bold"
      Foreground="#746D44" NavigateUri="https://avaloniaui.net/accelerate"/>

    <CommandBar
      Grid.Row="1" Grid.Column="0"
      MinHeight="0" Margin="2"
      DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
      <CommandBar.PrimaryCommands>
        <CommandBarToggleButton
          Classes="Tab"
          Command="{Binding SelectView}"
          CommandParameter="{x:Static diag:DevToolsViewKind.Elements}"
          IsChecked="{Binding IsElementsSelected, Mode=OneWay}"
          Label="Elements">
          <CommandBarToggleButton.Icon>
            <Image
              Classes="Icon"
              Source="{StaticResource LucideMousePointerClick}"/>
          </CommandBarToggleButton.Icon>
        </CommandBarToggleButton>

        <CommandBarToggleButton
          Classes="Tab"
          Command="{Binding SelectView}"
          CommandParameter="{x:Static diag:DevToolsViewKind.Events}"
          IsChecked="{Binding IsEventsSelected, Mode=OneWay}"
          Label="Events">
          <CommandBarToggleButton.Icon>
            <Image
              Classes="Icon"
              Source="{StaticResource LucideRadioTower}"/>
          </CommandBarToggleButton.Icon>
        </CommandBarToggleButton>

        <CommandBarToggleButton
          Classes="Tab"
          Command="{Binding SelectView}"
          CommandParameter="{x:Static diag:DevToolsViewKind.Trace}"
          IsChecked="{Binding IsTraceSelected, Mode=OneWay}"
          Label="Trace">
          <CommandBarToggleButton.Icon>
            <Image
              Classes="Icon"
              Source="{StaticResource LucideSquareTerminal}"/>
          </CommandBarToggleButton.Icon>
        </CommandBarToggleButton>

        <CommandBarToggleButton
          Classes="Tab"
          Command="{Binding SelectView}"
          CommandParameter="{x:Static diag:DevToolsViewKind.HotKeys}"
          IsChecked="{Binding IsHotKeysSelected, Mode=OneWay}"
          Label="HotKeys">
          <CommandBarToggleButton.Icon>
            <Image
              Classes="Icon"
              Source="{StaticResource LucideKeyboard}"/>
          </CommandBarToggleButton.Icon>
        </CommandBarToggleButton>

        <CommandBarToggleButton
          Classes="Tab"
          Command="{Binding SelectView}"
          CommandParameter="{x:Static diag:DevToolsViewKind.Settings}"
          IsChecked="{Binding IsSettingsSelected, Mode=OneWay}"
          Label="Settings">
          <CommandBarToggleButton.Icon>
            <Image
              Classes="Icon"
              Source="{StaticResource LucideSettings}"/>
          </CommandBarToggleButton.Icon>
        </CommandBarToggleButton>
      </CommandBar.PrimaryCommands>
    </CommandBar>

    <Menu
      Grid.Row="1" Grid.Column="1">
      <MenuItem>
        <MenuItem.Header>
          <Image
            Classes="Icon"
            Source="{StaticResource LucideMenu}"/>
        </MenuItem.Header>

        <MenuItem Header="_File">
          <MenuItem
            Command="{Binding $parent[Window].Close}"
            Header="E_xit"/>
          <MenuItem
            Command="{Binding Shot}"
            Header="Screenshot" HotKey="F8">
            <MenuItem.Icon>
              <Image/>
            </MenuItem.Icon>
          </MenuItem>
        </MenuItem>
      </MenuItem>
    </Menu>

    <ContentControl
      Grid.Row="2" Grid.Column="0"
      Grid.ColumnSpan="2"
      BorderBrush="{DynamicResource ThemeControlMidBrush}"
      BorderThickness="0,1,0,0"
      Content="{Binding Content}"/>

    <Border
      Grid.Row="3" Grid.Column="0"
      Grid.ColumnSpan="2"
      BorderBrush="{DynamicResource ThemeControlMidBrush}"
      BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel
          Grid.Column="0" Orientation="Horizontal"
          Spacing="4">
          <TextBlock>Hold Ctrl+Shift over a control to inspect.</TextBlock>
          <Separator Margin="4,0"/>
          <TextBlock>Focused:</TextBlock>
          <TextBlock Text="{Binding FocusedControl}"/>
          <Separator Margin="4,0"/>
          <TextBlock>Pointer Over:</TextBlock>
          <TextBlock Text="{Binding PointerOverElementName}"/>
        </StackPanel>

        <TextBlock
          Grid.Column="1" Margin="2,0"
          Foreground="Gray"
          IsVisible="{Binding FreezePopups}"
          Text="Popups frozen"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
