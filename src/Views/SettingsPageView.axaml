<UserControl
  x:Class="RolandUI.DevScope.Views.SettingsPageView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:RolandUI.DevScope.ViewModels"
  x:DataType="vm:SettingsPageViewModel">
  <UserControl.Styles>
    <Style Selector="Border.SettingsSection">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="TextBlock.SettingsSectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style Selector="StackPanel.SettingsOption">
      <Setter Property="Spacing" Value="4"/>
    </Style>

    <Style Selector="Border.FocusHighlighterSwatch">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer>
    <StackPanel
      Margin="8" Spacing="0">
      <Border Classes="SettingsSection">
        <StackPanel Classes="SettingsOption">
          <TextBlock
            Classes="SettingsSectionTitle" Text="Inspector"/>
          <CheckBox
            Content="Show Implemented Interfaces"
            IsChecked="{Binding MainView.ShowImplementedInterfaces, Mode=TwoWay}"/>
          <CheckBox
            Content="Split Property Type"
            IsChecked="{Binding MainView.ShowDetailsPropertyType, Mode=TwoWay}"/>
        </StackPanel>
      </Border>

      <Border Classes="SettingsSection">
        <StackPanel Classes="SettingsOption">
          <TextBlock
            Classes="SettingsSectionTitle" Text="Overlays"/>
          <CheckBox
            Content="Margin/Padding"
            IsChecked="{Binding MainView.ShouldVisualizeMarginPadding}"/>
          <CheckBox
            Content="Dirty Rects"
            IsChecked="{Binding MainView.ShowDirtyRectsOverlay}"/>
          <CheckBox
            Content="FPS"
            IsChecked="{Binding MainView.ShowFpsOverlay}"/>
          <CheckBox
            Content="Layout Time Graph"
            IsChecked="{Binding MainView.ShowLayoutTimeGraphOverlay}"/>
          <CheckBox
            Content="Render Time Graph"
            IsChecked="{Binding MainView.ShowRenderTimeGraphOverlay}"/>
        </StackPanel>
      </Border>

      <Border Classes="SettingsSection">
        <StackPanel Classes="SettingsOption">
          <TextBlock
            Classes="SettingsSectionTitle" Text="Focus Highlighter"/>
          <RadioButton
            Command="{Binding MainView.SelectFocusHighlighter}"
            CommandParameter="{x:Null}"
            Content="None"
            IsChecked="{Binding MainView.FocusHighlighter, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Null}}"/>
          <RadioButton
            Command="{Binding MainView.SelectFocusHighlighter}"
            CommandParameter="{x:Static Brushes.Red}"
            IsChecked="{Binding MainView.FocusHighlighter, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static Brushes.Red}}">
            <StackPanel Orientation="Horizontal">
              <Border
                Classes="FocusHighlighterSwatch" Background="Red"/>
              <TextBlock Text="Red"/>
            </StackPanel>
          </RadioButton>
          <RadioButton
            Command="{Binding MainView.SelectFocusHighlighter}"
            CommandParameter="{x:Static Brushes.Blue}"
            IsChecked="{Binding MainView.FocusHighlighter, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static Brushes.Blue}}">
            <StackPanel Orientation="Horizontal">
              <Border
                Classes="FocusHighlighterSwatch" Background="Blue"/>
              <TextBlock Text="Blue"/>
            </StackPanel>
          </RadioButton>
          <RadioButton
            Command="{Binding MainView.SelectFocusHighlighter}"
            CommandParameter="{x:Static Brushes.Black}"
            IsChecked="{Binding MainView.FocusHighlighter, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static Brushes.Black}}">
            <StackPanel Orientation="Horizontal">
              <Border
                Classes="FocusHighlighterSwatch" Background="Black"/>
              <TextBlock Text="Black"/>
            </StackPanel>
          </RadioButton>
          <RadioButton
            Command="{Binding MainView.SelectFocusHighlighter}"
            CommandParameter="{x:Static Brushes.White}"
            IsChecked="{Binding MainView.FocusHighlighter, Mode=OneWay, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static Brushes.White}}">
            <StackPanel Orientation="Horizontal">
              <Border
                Classes="FocusHighlighterSwatch" Background="White"/>
              <TextBlock Text="White"/>
            </StackPanel>
          </RadioButton>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>