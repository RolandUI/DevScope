<UserControl
  x:Class="ClassicDiagnostics.Avalonia.Views.ControlStylesView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:ClassicDiagnostics.Avalonia.Controls"
  xmlns:local="using:ClassicDiagnostics.Avalonia.Views" xmlns:valueConverters="clr-namespace:ClassicDiagnostics.Avalonia.ValueConverters"
  xmlns:vm="using:ClassicDiagnostics.Avalonia.ViewModels" x:Name="Main"
  x:DataType="vm:ControlDetailsViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <Grid
      Grid.Row="0"
      IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}"
      RowDefinitions="Auto,*">
      <TextBlock
        Grid.Row="0" Margin="4"
        FontWeight="Bold" Text="Layout Visualizer"/>
      <local:LayoutExplorerView
        Grid.Row="1"
        DataContext="{Binding Layout}"/>
    </Grid>

    <StackPanel
      Grid.Row="1"
      Margin="4"
      IsVisible="{Binding HasStyleClassSection}"
      Spacing="4">
      <TextBlock
        FontWeight="Bold"
        Text="Classes"/>
      <ItemsControl ItemsSource="{Binding Classes}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:StyleClassViewModel">
            <Border
              Margin="0,0,4,4"
              Padding="4,1"
              BorderBrush="{DynamicResource ThemeControlMidBrush}"
              BorderThickness="1"
              CornerRadius="2">
              <StackPanel
                Orientation="Horizontal"
                Spacing="4">
                <TextBlock
                  VerticalAlignment="Center"
                  Text="{Binding Name}"/>
                <Button
                  Padding="4,0"
                  Command="{Binding Remove}"
                  Content="x"
                  ToolTip.Tip="Remove class"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <Grid ColumnDefinitions="*,Auto">
        <TextBox
          Grid.Column="0"
          PlaceholderText="Add class"
          Text="{Binding NewClassName, Mode=TwoWay}"/>
        <Button
          Grid.Column="1"
          Margin="4,0,0,0"
          Command="{Binding AddClass}"
          Content="Add"/>
      </Grid>
      <TextBlock
        Foreground="Red"
        IsVisible="{Binding ClassEditError, Converter={x:Static ObjectConverters.IsNotNull}}"
        Text="{Binding ClassEditError}"/>
    </StackPanel>

    <StackPanel
      Grid.Row="2"
      Margin="4"
      IsVisible="{Binding HasStyleClassSection}"
      Spacing="4">
      <TextBlock
        FontWeight="Bold"
        Text="Pseudo Classes"/>
      <ItemsControl ItemsSource="{Binding PseudoClasses}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:PseudoClassViewModel">
            <StackPanel Spacing="2">
              <CheckBox
                Content="{Binding Name}"
                IsChecked="{Binding IsActive, Mode=TwoWay}"/>
              <TextBlock
                Margin="20,0,0,0"
                Foreground="Red"
                IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}"
                Text="{Binding Error}"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <Grid ColumnDefinitions="*,Auto">
        <TextBox
          Grid.Column="0"
          PlaceholderText="Add pseudo class"
          Text="{Binding NewPseudoClassName, Mode=TwoWay}"/>
        <Button
          Grid.Column="1"
          Margin="4,0,0,0"
          Command="{Binding AddPseudoClass}"
          Content="Add"/>
      </Grid>
      <TextBlock
        Foreground="Red"
        IsVisible="{Binding PseudoClassEditError, Converter={x:Static ObjectConverters.IsNotNull}}"
        Text="{Binding PseudoClassEditError}"/>
    </StackPanel>

    <Grid
      Grid.Row="3" Margin="4"
      RowDefinitions="Auto,Auto,*">

      <Grid
        Grid.Row="0" Margin="2"
        ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock
          Grid.Column="0" VerticalAlignment="Center"
          FontWeight="Bold"
          Text="{Binding FramesStatus}"/>
        <CheckBox
          Grid.Column="2" Margin="2,0,0,0"
          Content="Show inactive"
          IsChecked="{Binding ShowInactiveFrames}"
          ToolTip.Tip="Show values that are currently inactive"/>
        <ToggleButton
          Grid.Column="3" Margin="2,0,0,0"
          Content="Snapshot"
          IsChecked="{Binding SnapshotFrames}"
          ToolTip.Tip="Snapshot current values (Alt+S/Alt+D to enable/disable within debugged window)"/>
      </Grid>

      <controls:FilterTextBox
        Grid.Row="1" Grid.Column="0"
        Margin="2"
        DataContext="{Binding TreePage.SettersFilter}"
        PlaceholderText="Filter values"
        Text="{Binding FilterString}"
        UseCaseSensitiveFilter="{Binding UseCaseSensitiveFilter}"
        UseRegexFilter="{Binding UseRegexFilter}"
        UseWholeWordFilter="{Binding UseWholeWordFilter}"/>

      <ScrollViewer
        Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding AppliedFrames}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border
                BorderBrush="#6C6C6C" BorderThickness="0,0,0,1"
                Opacity="{Binding IsActive, Converter={x:Static valueConverters:BoolToOpacityConverter.Shared}}">
                <Border.IsVisible>
                  <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                      <Binding Path="IsActive"/>
                      <Binding Path="#Main.ViewModel?.ShowInactiveFrames" TargetNullValue="False"/>
                    </MultiBinding>
                    <Binding Path="IsVisible"/>
                  </MultiBinding>
                </Border.IsVisible>
                <Expander
                  Margin="0" Padding="8,0"
                  ContentTransition="{x:Null}"
                  IsExpanded="True">
                  <Expander.Header>
                    <TextBlock Text="{Binding Description}"/>
                  </Expander.Header>

                  <ItemsControl
                    Margin="20,0,0,0"
                    ItemsSource="{Binding Setters}">
                    <ItemsControl.Styles>
                      <Style Selector="TextBlock.property-name">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Background" Value="Transparent"/>
                      </Style>

                      <Style Selector="TextBlock.property-name:pointerover">
                        <Setter Property="TextDecorations" Value="Underline"/>
                      </Style>

                      <Style Selector="Rectangle.property-inactive">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Setter Property="Height" Value="1"/>
                        <Setter Property="Fill" Value="#6C6C6C"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                      </Style>
                    </ItemsControl.Styles>

                    <ItemsControl.DataTemplates>
                      <DataTemplate DataType="IBrush">
                        <StackPanel
                          Orientation="Horizontal" Spacing="2">
                          <Border
                            Width="8" Height="8"
                            Background="{Binding}"
                            BorderBrush="Black" BorderThickness="1"/>
                          <TextBlock Text="{Binding}"/>
                        </StackPanel>
                      </DataTemplate>

                      <DataTemplate DataType="Color">
                        <StackPanel
                          Orientation="Horizontal" Spacing="2">
                          <Border
                            Width="8" Height="8"
                            BorderBrush="Black" BorderThickness="1">
                            <Border.Background>
                              <SolidColorBrush Color="{Binding}"/>
                            </Border.Background>
                          </Border>
                          <TextBlock Text="{Binding}"/>
                        </StackPanel>
                      </DataTemplate>

                      <DataTemplate DataType="vm:BindingSetterViewModel">
                        <Panel
                          HorizontalAlignment="Left"
                          IsVisible="{Binding IsVisible}"
                          Opacity="{Binding IsActive, Converter={x:Static valueConverters:BoolToOpacityConverter.Shared}}">
                          <Panel.ContextMenu>
                            <ContextMenu>
                              <MenuItem
                                Command="{Binding CopyPropertyName}"
                                Header="Copy property name"/>
                              <MenuItem
                                Command="{Binding CopyValue}"
                                Header="Copy value"/>
                            </ContextMenu>
                          </Panel.ContextMenu>
                          <StackPanel
                            Orientation="Horizontal" Spacing="2">
                            <TextBlock
                              Classes="property-name" PointerPressed="HandlePropertyNamePointerPressed"
                              Text="{Binding Name}"/>
                            <TextBlock Text=":"/>
                            <TextBlock>{</TextBlock>
                            <Rectangle
                              Width="8" Height="8"
                              VerticalAlignment="Center"
                              Fill="{Binding Tint}"
                              ToolTip.Tip="{Binding ValueTypeTooltip}"/>
                            <TextBlock Text="{Binding Path}"/>
                            <TextBlock>}</TextBlock>
                          </StackPanel>
                          <Rectangle
                            Classes="property-inactive"
                            IsVisible="{Binding !IsActive}"/>
                        </Panel>
                      </DataTemplate>

                      <DataTemplate DataType="vm:ResourceSetterViewModel">
                        <Panel
                          HorizontalAlignment="Left"
                          IsVisible="{Binding IsVisible}"
                          Opacity="{Binding IsActive, Converter={x:Static valueConverters:BoolToOpacityConverter.Shared}}">
                          <Panel.ContextMenu>
                            <ContextMenu>
                              <MenuItem
                                Command="{Binding CopyPropertyName}"
                                Header="Copy property name"/>
                              <MenuItem
                                Command="{Binding CopyValue}"
                                Header="Copy value"/>
                              <MenuItem
                                Command="{Binding CopyResourceKey}"
                                Header="Copy resource key"/>
                            </ContextMenu>
                          </Panel.ContextMenu>
                          <StackPanel
                            HorizontalAlignment="Left" Orientation="Horizontal"
                            Spacing="2">
                            <TextBlock
                              Classes="property-name" PointerPressed="HandlePropertyNamePointerPressed"
                              Text="{Binding Name}"/>
                            <TextBlock Text=":"/>
                            <TextBlock Text="{Binding Value}"/>
                            <TextBlock>(</TextBlock>
                            <Ellipse
                              Width="8" Height="8"
                              VerticalAlignment="Center"
                              Fill="{Binding Tint}"
                              ToolTip.Tip="{Binding ValueTypeTooltip}"/>
                            <TextBlock
                              FontStyle="Italic"
                              Text="{Binding Key}"/>
                            <TextBlock>)</TextBlock>
                          </StackPanel>
                          <Rectangle
                            Classes="property-inactive"
                            IsVisible="{Binding !IsActive}"/>
                        </Panel>
                      </DataTemplate>

                      <DataTemplate DataType="vm:SetterViewModel">
                        <Panel
                          HorizontalAlignment="Left"
                          IsVisible="{Binding IsVisible}"
                          Opacity="{Binding IsActive, Converter={x:Static valueConverters:BoolToOpacityConverter.Shared}}">
                          <Panel.ContextMenu>
                            <ContextMenu>
                              <MenuItem
                                Command="{Binding CopyPropertyName}"
                                Header="Copy property name"/>
                              <MenuItem
                                Command="{Binding CopyValue}"
                                Header="Copy value"/>
                            </ContextMenu>
                          </Panel.ContextMenu>
                          <StackPanel
                            Orientation="Horizontal" Spacing="2">
                            <TextBlock
                              Classes="property-name" PointerPressed="HandlePropertyNamePointerPressed"
                              Text="{Binding Name}"/>
                            <TextBlock Text=":"/>
                            <TextBlock Text="{Binding Value}"/>
                          </StackPanel>
                          <Rectangle
                            Classes="property-inactive"
                            IsVisible="{Binding !IsActive}"/>
                        </Panel>
                      </DataTemplate>
                    </ItemsControl.DataTemplates>
                  </ItemsControl>
                </Expander>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Grid>
  </Grid>
</UserControl>
