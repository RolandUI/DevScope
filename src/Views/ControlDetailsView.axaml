<UserControl
  x:Class="ClassicDiagnostics.Avalonia.Views.ControlDetailsView" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ap="clr-namespace:ClassicDiagnostics.Avalonia.AttachedProperties"
  xmlns:controls="using:ClassicDiagnostics.Avalonia.Controls" xmlns:conv="using:ClassicDiagnostics.Avalonia.Converters"
  xmlns:local="using:ClassicDiagnostics.Avalonia.Views" xmlns:vm="using:ClassicDiagnostics.Avalonia.ViewModels"
  x:Name="Main" x:DataType="vm:ControlDetailsViewModel">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Assets/Icons.axaml"/>
      </ResourceDictionary.MergedDictionaries>
      <conv:BoolToOpacityConverter
        x:Key="BoolToOpacity" Opacity="0.6"/>
      <conv:GetTypeNameConverter x:Key="GetTypeName"/>
      <conv:BoolToImageConverter
        x:Key="pc"
        FalseImage="{StaticResource UnpinIcon}"
        TrueImage="{StaticResource PinIcon}"/>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.Pinned">
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
  </UserControl.Styles>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
      <!--
        When selecting the Application node, we need this trick to hide Layout Visualizer
        because when using the GridSplitter it sets the Width property of ColumnDefinition
        (see https://github.com/AvaloniaUI/Avalonia/blob/master/src/Avalonia.Controls/GridSplitter.cs#L528)
        and if we hide the contents of the column, the space is not reclaimed
        (see discussion https://github.com/AvaloniaUI/Avalonia/discussions/6773).
      -->
      <ColumnDefinition
        Width="320"
        ap:ColumnDefinitionAssist.IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}"/>
    </Grid.ColumnDefinitions>

    <Grid
      Grid.Column="0" RowDefinitions="Auto,Auto,*">

      <Grid
        ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
        <Button
          Grid.RowSpan="2" Grid.Column="0"
          Margin="0,0,4,0"
          Command="{Binding NavigateToParentProperty}"
          Content="^"
          IsEnabled="{Binding CanNavigateToParentProperty}"
          ToolTip.Tip="Navigate to parent property"/>
        <TextBlock
          Grid.Row="0" Grid.Column="1"
          FontWeight="Bold"
          Text="{Binding SelectedEntityName}"/>
        <TextBlock
          Grid.Row="1" Grid.Column="1"
          FontStyle="Italic"
          Text="{Binding SelectedEntityType}"/>
      </Grid>

      <controls:FilterTextBox
        Grid.Row="1" BorderThickness="0"
        DataContext="{Binding TreePage.PropertiesFilter}"
        PlaceholderText="Filter properties"
        Text="{Binding FilterString}"
        UseCaseSensitiveFilter="{Binding UseCaseSensitiveFilter}"
        UseRegexFilter="{Binding UseRegexFilter}"
        UseWholeWordFilter="{Binding UseWholeWordFilter}"/>

      <DataGrid
        x:Name="DataGrid" Grid.Row="2"
        BorderThickness="0" CanUserResizeColumns="true"
        DoubleTapped="PropertiesGrid_OnDoubleTapped"
        ItemsSource="{Binding PropertiesView}"
        RowBackground="Transparent"
        SelectedItem="{Binding SelectedProperty, Mode=TwoWay}">
        <DataGrid.Columns>
          <DataGridTemplateColumn
            x:DataType="vm:PropertyViewModel" Header="Property"
            IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="vm:PropertyViewModel">
                <!--
                  Do not remove the DockPanel background set to Transparent
                  because if Background is null HitTest on empty space returns false
                -->
                <DockPanel Background="Transparent">
                  <DockPanel.Styles>
                    <Style Selector="DockPanel[IsPointerOver=False] &gt; ToggleButton">
                      <Setter Property="IsVisible" Value="False"/>
                    </Style>
                  </DockPanel.Styles>
                  <ToggleButton
                    DockPanel.Dock="Right" Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding #Main.((vm:ControlDetailsViewModel)DataContext).TogglePinnedProperty}"
                    CommandParameter="{Binding}"
                    IsChecked="{Binding IsPinned}">
                    <Image
                      Width="12" Height="12"
                      Source="{Binding IsPinned, Converter={StaticResource pc}}"/>
                  </ToggleButton>
                  <TextBlock
                    VerticalAlignment="Center"
                    Classes.Pinned="{Binding IsPinned}"
                    Text="{Binding Name}"/>
                </DockPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn
            Width="100" Header="Value">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <local:PropertyValueEditorView/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn
            x:DataType="vm:PropertyViewModel"
            Binding="{Binding Type}"
            Header="Type" IsReadOnly="True"
            IsVisible="{Binding !$parent[UserControl;2].((vm:MainViewModel)DataContext).ShowDetailsPropertyType}"/>
          <DataGridTextColumn
            x:DataType="vm:PropertyViewModel"
            Binding="{Binding AssignedType, Converter={StaticResource GetTypeName}}"
            Header="Assigned Type" IsReadOnly="True"
            IsVisible="{Binding $parent[UserControl;2].((vm:MainViewModel)DataContext).ShowDetailsPropertyType}"/>
          <DataGridTextColumn
            x:DataType="vm:PropertyViewModel"
            Binding="{Binding PropertyType, Converter={StaticResource GetTypeName}}"
            Header="Property Type" IsReadOnly="True"
            IsVisible="{Binding $parent[UserControl;2].((vm:MainViewModel)DataContext).ShowDetailsPropertyType}"/>
          <DataGridTextColumn
            x:DataType="vm:PropertyViewModel"
            Binding="{Binding Priority}"
            Header="Priority" IsReadOnly="True"/>
        </DataGrid.Columns>

        <DataGrid.Styles>
          <Style Selector="DataGridRow TextBox">
            <Setter Property="SelectionBrush" Value="LightBlue"/>
          </Style>
        </DataGrid.Styles>
      </DataGrid>

    </Grid>

    <GridSplitter Grid.Column="1"/>

    <Grid
      Grid.Column="2"
      IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}"
      RowDefinitions="*,Auto,*">

      <Grid
        Grid.Row="0" RowDefinitions="Auto,*">
        <TextBlock
          Grid.Row="0" Margin="4"
          FontWeight="Bold" Text="Layout Visualizer"/>
        <local:LayoutExplorerView
          Grid.Row="1"
          DataContext="{Binding Layout}"/>
      </Grid>

      <GridSplitter Grid.Row="1"/>

      <Grid
        Grid.Row="2" RowDefinitions="Auto,*,Auto">

        <Grid
          Grid.Row="0" Margin="4"
          RowDefinitions="Auto,Auto">

          <Grid
            Grid.Row="0" Margin="2"
            ColumnDefinitions="Auto,*,Auto,Auto">
            <TextBlock
              Grid.Column="0" VerticalAlignment="Center"
              FontWeight="Bold"
              Text="{Binding FramesStatus}"/>
            <CheckBox
              Grid.Column="2" Margin="2,0,0,0"
              Content="Show inactive"
              IsChecked="{Binding ShowInactiveFrames}"
              ToolTip.Tip="Show values that are currently inactive"/>
            <ToggleButton
              Grid.Column="3" Margin="2,0,0,0"
              Content="Snapshot"
              IsChecked="{Binding SnapshotFrames}"
              ToolTip.Tip="Snapshot current values (Alt+S/Alt+D to enable/disable within debugged window)"/>
          </Grid>

          <controls:FilterTextBox
            Grid.Row="1" Grid.Column="0"
            Margin="2"
            DataContext="{Binding TreePage.SettersFilter}"
            PlaceholderText="Filter values"
            Text="{Binding FilterString}"
            UseCaseSensitiveFilter="{Binding UseCaseSensitiveFilter}"
            UseRegexFilter="{Binding UseRegexFilter}"
            UseWholeWordFilter="{Binding UseWholeWordFilter}"/>
        </Grid>

        <ScrollViewer
          Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding AppliedFrames}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border
                  BorderBrush="#6C6C6C" BorderThickness="0,0,0,1"
                  Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacity}}">
                  <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                      <MultiBinding Converter="{x:Static BoolConverters.Or}">
                        <Binding Path="IsActive"/>
                        <!--  Rider marks it as an error, because it doesn't know about new binding rules yet.  -->
                        <Binding Path="#Main.DataContext.ShowInactiveFrames"/>
                      </MultiBinding>
                      <Binding Path="IsVisible"/>
                    </MultiBinding>
                  </Border.IsVisible>
                  <Expander
                    Margin="0" Padding="8,0"
                    ContentTransition="{x:Null}"
                    IsExpanded="True">
                    <Expander.Header>
                      <TextBlock
                        Grid.Row="0"
                        Text="{Binding Description}"/>
                    </Expander.Header>

                    <ItemsControl
                      Margin="20,0,0,0"
                      ItemsSource="{Binding Setters}">

                      <ItemsControl.Styles>
                        <Style Selector="TextBlock.property-name">
                          <Setter Property="FontWeight" Value="SemiBold"/>
                          <Setter Property="Background" Value="Transparent"/>
                        </Style>

                        <Style Selector="TextBlock.property-name:pointerover">
                          <Setter Property="TextDecorations" Value="Underline"/>
                        </Style>

                        <Style Selector="Rectangle.property-inactive">
                          <Setter Property="IsHitTestVisible" Value="False"/>
                          <Setter Property="Height" Value="1"/>
                          <Setter Property="Fill" Value="#6C6C6C"/>
                          <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>

                      </ItemsControl.Styles>

                      <ItemsControl.DataTemplates>

                        <DataTemplate DataType="IBrush">
                          <StackPanel
                            Orientation="Horizontal" Spacing="2">
                            <Border
                              Width="8" Height="8"
                              Background="{Binding}"
                              BorderBrush="Black" BorderThickness="1"/>
                            <TextBlock Text="{Binding}"/>
                          </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="Color">
                          <StackPanel
                            Orientation="Horizontal" Spacing="2">
                            <Border
                              Width="8" Height="8"
                              BorderBrush="Black" BorderThickness="1">
                              <Border.Background>
                                <SolidColorBrush Color="{Binding}"/>
                              </Border.Background>
                            </Border>
                            <TextBlock Text="{Binding}"/>
                          </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="vm:BindingSetterViewModel">
                          <Panel
                            HorizontalAlignment="Left"
                            IsVisible="{Binding IsVisible}"
                            Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacity}}">
                            <Panel.ContextMenu>
                              <ContextMenu>
                                <MenuItem
                                  Command="{Binding CopyPropertyName}"
                                  Header="Copy property name"/>
                                <MenuItem
                                  Command="{Binding CopyValue}"
                                  Header="Copy value"/>
                              </ContextMenu>
                            </Panel.ContextMenu>
                            <StackPanel
                              Orientation="Horizontal" Spacing="2">
                              <TextBlock
                                Classes="property-name" PointerPressed="PropertyNamePressed"
                                Text="{Binding Name}"/>
                              <TextBlock Text=":"/>
                              <TextBlock>{</TextBlock>
                              <Rectangle
                                Width="8" Height="8"
                                VerticalAlignment="Center"
                                Fill="{Binding Tint}"
                                ToolTip.Tip="{Binding ValueTypeTooltip}"/>
                              <TextBlock Text="{Binding Path}"/>
                              <TextBlock>}</TextBlock>
                            </StackPanel>
                            <Rectangle
                              Classes="property-inactive"
                              IsVisible="{Binding !IsActive}"/>
                          </Panel>
                        </DataTemplate>

                        <DataTemplate DataType="vm:ResourceSetterViewModel">
                          <Panel
                            HorizontalAlignment="Left"
                            IsVisible="{Binding IsVisible}"
                            Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacity}}">
                            <Panel.ContextMenu>
                              <ContextMenu>
                                <MenuItem
                                  Command="{Binding CopyPropertyName}"
                                  Header="Copy property name"/>
                                <MenuItem
                                  Command="{Binding CopyValue}"
                                  Header="Copy value"/>
                                <MenuItem
                                  Command="{Binding CopyResourceKey}"
                                  Header="Copy resource key"/>
                              </ContextMenu>
                            </Panel.ContextMenu>
                            <StackPanel
                              HorizontalAlignment="Left" Orientation="Horizontal"
                              Spacing="2">
                              <TextBlock
                                Classes="property-name" PointerPressed="PropertyNamePressed"
                                Text="{Binding Name}"/>
                              <TextBlock Text=":"/>
                              <TextBlock Text="{Binding Value}"/>
                              <TextBlock>(</TextBlock>
                              <Ellipse
                                Width="8" Height="8"
                                VerticalAlignment="Center"
                                Fill="{Binding Tint}"
                                ToolTip.Tip="{Binding ValueTypeTooltip}"/>
                              <TextBlock
                                FontStyle="Italic"
                                Text="{Binding Key}"/>
                              <TextBlock>)</TextBlock>
                            </StackPanel>
                            <Rectangle
                              Classes="property-inactive"
                              IsVisible="{Binding !IsActive}"/>
                          </Panel>
                        </DataTemplate>

                        <DataTemplate DataType="vm:SetterViewModel">
                          <Panel
                            HorizontalAlignment="Left"
                            IsVisible="{Binding IsVisible}"
                            Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacity}}">
                            <Panel.ContextMenu>
                              <ContextMenu>
                                <MenuItem
                                  Command="{Binding CopyPropertyName}"
                                  Header="Copy property name"/>
                                <MenuItem
                                  Command="{Binding CopyValue}"
                                  Header="Copy value"/>
                              </ContextMenu>
                            </Panel.ContextMenu>
                            <StackPanel
                              Orientation="Horizontal" Spacing="2">
                              <TextBlock
                                Classes="property-name" PointerPressed="PropertyNamePressed"
                                Text="{Binding Name}"/>
                              <TextBlock Text=":"/>
                              <TextBlock Text="{Binding Value}"/>
                            </StackPanel>
                            <Rectangle
                              Classes="property-inactive"
                              IsVisible="{Binding !IsActive}"/>
                          </Panel>
                        </DataTemplate>

                      </ItemsControl.DataTemplates>
                    </ItemsControl>

                  </Expander>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Expander
          Grid.Row="2" Header="Pseudo Classes">
          <ItemsControl ItemsSource="{Binding PseudoClasses}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox
                  Margin="2"
                  Content="{Binding Name}"
                  IsChecked="{Binding IsActive, Mode=TwoWay}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Expander>

      </Grid>

    </Grid>
  </Grid>

</UserControl>